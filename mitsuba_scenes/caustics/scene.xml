<scene version="3.0.0">
    <integrator type="path">
        <integer name="max_depth" value="6"/>
    </integrator>

    <sensor type="perspective">
        <!-- Vertical FOV assumed ~30 degrees based on typical cornell box setups 
             matching this focal length/sensor ratio -->
        <string name="fov_axis" value="y"/>
        <float name="fov" value="30"/>
        
        <float name="near_clip" value="0.1"/>
        <float name="far_clip" value="100.0"/>

        <transform name="to_world">
            <!-- 
                Calculated from C:
                Focus: (0, 1.05, 0)
                Dist: 4.0
                AngleX: 0.4 rad
                Y = 1.05 + 4.0 * sin(0.4) = 2.60767
                Z = 0.0 + 4.0 * cos(0.4) = 3.68424
            -->
            <lookat origin="0, 2.6077, 3.6842" 
                    target="0, 1.05, 0" 
                    up    ="0, 1, 0"/>
        </transform>

        <film type="hdrfilm">
            <integer name="width" value="280"/>
            <integer name="height" value="320"/>
            <rfilter type="box"/>
        </film>

        <sampler type="independent">
            <integer name="sample_count" value="1000000"/>
        </sampler>
    </sensor>
    
    <!-- Materials -->
    <bsdf type="diffuse" id="mat_floor">
        <rgb name="reflectance" value="0.75, 0.75, 0.75"/>
    </bsdf>

    <bsdf type="dielectric" id="mat_glass">
        <!-- C color.x = 1.5 implies IOR -->
        <float name="int_ior" value="1.5"/>
        <float name="ext_ior" value="1.0"/>
        <rgb name="specular_transmittance" value="1.0, 1.0, 1.0"/>
    </bsdf>

    <!-- Geometry -->

    <!-- Floor: Single Triangle -->
    <!-- Vertices: {-2, 0, -2}, {0, 0, 2}, { 2, 0, -2} -->
    <shape type="obj">
        <string name="filename" value="floor.obj"/>
        <ref id="mat_floor"/>
    </shape>

    <!-- Glass Sphere 1 (Main) -->
    <shape type="sphere">
        <transform name="to_world">
            <scale value="0.75"/>
            <translate x="0.0" y="1.3" z="0.0"/>
        </transform>
        <ref id="mat_glass"/>
    </shape>

    <!-- Glass Sphere 2 (Right) -->
    <shape type="sphere">
        <transform name="to_world">
            <scale value="0.2"/>
            <translate x="0.3" y="0.3" z="0.0"/>
        </transform>
        <ref id="mat_glass"/>
    </shape>

    <!-- Glass Sphere 3 (Left) -->
    <shape type="sphere">
        <transform name="to_world">
            <scale value="0.2"/>
            <translate x="-0.3" y="0.3" z="0.0"/>
        </transform>
        <ref id="mat_glass"/>
    </shape>

    <!-- Light 1: Top/Right Triangle (Greenish) -->
    <!-- Color: {21.5, 107.5, 21.5} -> Radiance ~ {6.84, 34.21, 6.84} -->
    <shape type="obj">
        <string name="filename" value="light_tri_1.obj"/>
        <emitter type="area">
            <rgb name="radiance" value="6.8437, 34.2183, 6.8437"/>
        </emitter>
    </shape>

    <!-- Light 2: Bottom/Left Triangle (Bluish) -->
    <!-- Color: {21.5, 21.5, 107.5} -> Radiance ~ {6.84, 6.84, 34.21} -->
    <shape type="obj">
        <string name="filename" value="light_tri_2.obj"/>
        <emitter type="area">
            <rgb name="radiance" value="6.8437, 6.8437, 34.2183"/>
        </emitter>
    </shape>

</scene>
